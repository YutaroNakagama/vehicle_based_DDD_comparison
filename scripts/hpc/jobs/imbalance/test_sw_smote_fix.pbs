#!/bin/bash
#PBS -N test_sw_fix
#PBS -q SINGLE
#PBS -l select=1:ncpus=1:mem=16gb
#PBS -l walltime=1:00:00
#PBS -o logs/test_sw_smote_fix.out
#PBS -e logs/test_sw_smote_fix.err
#PBS -j oe

set -euo pipefail

export PATH=~/conda/bin:$PATH
source ~/conda/etc/profile.d/conda.sh
conda activate python310

export OMP_NUM_THREADS=1
export MKL_NUM_THREADS=1
export JOBLIB_MULTIPROCESSING=0
export PYTHONUNBUFFERED=1

PROJECT_ROOT="${PROJECT_ROOT:-/home/s2240011/git/ddd/vehicle_based_DDD_comparison}"
export PYTHONPATH=$PROJECT_ROOT:${PYTHONPATH:-}
cd $PROJECT_ROOT

echo "=== Testing SW-SMOTE fix ==="
echo "Python: $(which python)"
echo "Working dir: $(pwd)"

python scripts/python/train.py \
    --model RF \
    --tag rank_dtw_mean_high \
    --mode pooled \
    --use_oversampling \
    --subject_wise_oversampling \
    --target_ratio 0.5 \
    --seed 42 \
    --n_jobs 1

echo "Exit code: $?"
echo "=== Done ==="
